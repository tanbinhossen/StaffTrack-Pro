{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile with role and status",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "role"]
    },
    "Location": {
      "title": "Location",
      "description": "Real-time location data for a user",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "latitude": { "type": "number" },
        "longitude": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "latitude", "longitude", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles and roles"
    },
    "/locations/{userId}": {
      "schema": "Location",
      "description": "Active locations of users"
    }
  }
}
